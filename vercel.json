{
  "builds": [
    {
      "src": "app.py",
      "use": "vercel-python@latest",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "STREAMLIT_SERVER_HEADLESS": "true",
    "STREAMLIT_SERVER_ENABLEXSRFPROTECTION": "false",
    "STREAMLIT_CLIENT_TOOLBARPOSITION": "bottom"
  }
}
